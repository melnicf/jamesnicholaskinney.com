# Sanity (required for Studio and GROQ)
# Project: James Nicholas Kinney (cvjrh10b), dataset: production
NEXT_PUBLIC_SANITY_PROJECT_ID= <your-project-id>
NEXT_PUBLIC_SANITY_DATASET= <your-dataset>

# Optional: token for draft/live preview (create in manage.sanity.io)
# SANITY_API_READ_TOKEN=

# Sanity write token for ingestion pipeline (create in manage.sanity.io → API → Tokens)
SANITY_API_WRITE_TOKEN=

# Neon PostgreSQL connection string (https://console.neon.tech)
DATABASE_URL=

# OpenAI API key for categorization and summary generation
OPENAI_API_KEY=

# Secret to authenticate cron jobs and admin API routes
CRON_SECRET=
